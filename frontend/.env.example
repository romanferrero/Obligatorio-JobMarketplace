# ID de proyecto de WalletConnect/Reown Cloud (https://cloud.reown.com), gratis.
# Sin esto, RainbowKit funciona igual para wallets inyectadas (MetaMask) pero sin
# soporte de WalletConnect para wallets móviles/QR.
VITE_WALLETCONNECT_PROJECT_ID=

# RPC de Sepolia opcional. Si se deja vacío, wagmi usa el RPC público por defecto.
VITE_SEPOLIA_RPC_URL=
